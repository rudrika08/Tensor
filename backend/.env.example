# Application
APP_NAME=Tensor Credit Intelligence API
APP_VERSION=1.0.0
DEBUG=true

# Database (Docker service name = "postgres")
DATABASE_URL=postgresql+asyncpg://tensor:tensor123@postgres:5432/tensordb

# Storage — use "local" for dev, "s3" for production
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=uploads

# Google Maps (optional — Overpass API used as free fallback)
GOOGLE_MAPS_API_KEY=

# AWS S3 (optional — only needed if STORAGE_BACKEND=s3)
AWS_BUCKET_NAME=
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Vision model paths (auto-downloaded if not present)
YOLO_MODEL_PATH=models/yolov8n.pt
SAM_CHECKPOINT_PATH=models/sam_vit_h.pth
SAM_MODEL_TYPE=vit_h
MIDAS_MODEL_TYPE=DPT_Hybrid
CLIP_MODEL_NAME=ViT-B-32
CLIP_PRETRAINED=openai

# Validation thresholds
MIN_IMAGE_WIDTH=640
MIN_IMAGE_HEIGHT=480
BLUR_THRESHOLD=100.0
MAX_IMAGES_PER_SUBMISSION=5
MIN_IMAGES_PER_SUBMISSION=3
MAX_IMAGE_SIZE_MB=20
MAX_TEMPORAL_GAP_MINUTES=30
